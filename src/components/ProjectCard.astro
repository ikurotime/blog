---
interface Props {
  title: string
  description: string
  tags?: string[]
  href: string
}

const { title, description, tags = [], href } = Astro.props as Props
---

<a
  href={href}
  target='_blank'
  rel='noreferrer'
  class='group relative flex flex-col gap-2 rounded-lg border border-line p-5 transition-all hover:-translate-y-0.5 hover:border-ink/40 hover:bg-ink/[0.02]'
>
  <div class='flex items-start justify-between gap-3'>
    <h3
      class='text-[15px] font-medium text-ink transition-transform group-hover:translate-x-0.5'
    >
      {title}
    </h3>
    <svg
      xmlns='http://www.w3.org/2000/svg'
      width='14'
      height='14'
      viewBox='0 0 24 24'
      fill='none'
      stroke='currentColor'
      stroke-width='2'
      stroke-linecap='round'
      stroke-linejoin='round'
      class='shrink-0 text-muted transition-all group-hover:-translate-y-0.5 group-hover:translate-x-0.5 group-hover:text-ink'
      aria-hidden='true'
    >
      <path d='M7 17 17 7'></path>
      <path d='M7 7h10v10'></path>
    </svg>
  </div>
  <p class='text-sm text-muted'>{description}</p>
  {
    tags.length > 0 && (
      <ul class='mt-1 flex flex-wrap gap-1.5'>
        {tags.map((tag) => (
          <li class='rounded-md border border-line px-1.5 py-0.5 font-mono text-[10px] uppercase tracking-wide text-muted'>
            {tag}
          </li>
        ))}
      </ul>
    )
  }
</a>
