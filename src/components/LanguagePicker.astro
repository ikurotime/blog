---
import { languages } from '../i18n/ui'
import { getLangFromUrl } from '../i18n/utils'
const language = getLangFromUrl(Astro.url)
---

<ul class='flex gap-4'>
  {
    Object.entries(languages).map(([lang, label]) => (
      <li>
        <a
          href={`/${lang}/`}
          class={
            lang === language
              ? 'border-b border-b-neutral-950 dark:border-b-[#EBDBB2] '
              : 'text-neutral-600 dark:text-[#857B72] hover:opacity-70'
          }
        >
          {label}
        </a>
      </li>
    ))
  }
</ul>
