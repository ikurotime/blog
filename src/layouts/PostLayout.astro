---
import '@fontsource-variable/inter'
import '../styles/global.css'
import Prose from './Prose.astro'
import Head from '../components/Head.astro'
import Footer from './Footer.astro'
import Navbar from './Navbar.astro'
import ProgressBar from '../components/ProgressBar.astro'

const { language, frontmatter } = Astro.props
---

<html lang={language} class='bg-bg'>
  <head>
    <meta charset='utf-8' />
    <meta name='viewport' content='width=device-width,initial-scale=1' />
    <meta name='generator' content={Astro.generator} />
    <link
      rel='icon'
      href='data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>📚</text></svg>'
    />
    <Head
      title={frontmatter.title}
      description={frontmatter.description}
      keywords={frontmatter.keywords}
    />
    <script is:inline>
      ;(function () {
        try {
          const stored = localStorage.getItem('theme')
          const prefersDark = window.matchMedia(
            '(prefers-color-scheme: dark)'
          ).matches
          const theme = stored ? stored : prefersDark ? 'dark' : 'light'
          if (theme === 'dark') document.documentElement.classList.add('dark')
        } catch (_) {}
      })()
    </script>
  </head>
  <body
    class='font-sans bg-bg text-ink antialiased'
  >
    <ProgressBar />
    <div class='mx-auto w-full max-w-[680px] px-6 sm:px-8'>
      <Navbar />
      <article class='pb-16'>
        <header
          class='flex flex-col gap-3 border-b border-line pb-8 pt-8 reveal'
          style='--reveal-delay: 60ms'
        >
          <div
            class='flex items-center gap-3 font-mono text-[11px] text-muted'
          >
            <time>
              {new Date(frontmatter.pubDate).toLocaleDateString(
                language === 'es' ? 'es-ES' : 'en-US',
                { year: 'numeric', month: 'short', day: 'numeric' }
              )}
            </time>
            {
              frontmatter.tags?.length > 0 && (
                <>
                  <span class='text-muted/40'>·</span>
                  <span>{frontmatter.tags.join(', ')}</span>
                </>
              )
            }
          </div>
          <h1
            class='text-2xl sm:text-3xl font-semibold tracking-tight text-ink'
          >
            {frontmatter.title}
          </h1>
          {
            frontmatter.description && (
              <p class='text-[15px] text-muted'>
                {frontmatter.description}
              </p>
            )
          }
        </header>

        <div
          class='pt-8 reveal'
          style='--reveal-delay: 140ms'
        >
          <Prose frontmatter={frontmatter}>
            {
              frontmatter.wip && (
                <div
                  class='mb-6 rounded-md border border-amber-500/30 bg-amber-500/10 px-4 py-3 text-sm text-amber-700 dark:text-amber-300'
                >
                  {frontmatter.language === 'es'
                    ? '🛠️ Kuro está trabajando en este post. Todo deberia de funcionar como está indicado, pero puede que haya algunos errores.'
                    : '🛠️ Kuro is working on this post. Everything should work as indicated, but there may be some errors.'}
                </div>
              )
            }
            <slot />
          </Prose>
        </div>

        <div class='mt-12'>
          <script
            id='giscus-script'
            src='https://giscus.app/client.js'
            data-repo='ikurotime/blog-comments'
            data-repo-id='R_kgDOPtEulQ'
            data-category='Announcements'
            data-category-id='DIC_kwDOPtEulc4CvOdX'
            data-mapping='pathname'
            data-strict='0'
            data-reactions-enabled='1'
            data-emit-metadata='0'
            data-input-position='top'
            data-theme='light'
            data-lang='en'
            data-loading='lazy'
            crossorigin='anonymous'
            async></script>
        </div>
      </article>
      <Footer />
    </div>

    <script>
      const updateGiscusTheme = () => {
        const isDark = document.documentElement.classList.contains('dark')
        const giscus = document.getElementById('giscus-script')
        if (giscus) {
          giscus.setAttribute('data-theme', isDark ? 'dark' : 'light')
          // @ts-ignore
          if (window.giscus) window.giscus.reset()
        }
      }
      updateGiscusTheme()
      new MutationObserver(updateGiscusTheme).observe(
        document.documentElement,
        { attributes: true, attributeFilter: ['class'] }
      )
    </script>

    <style is:global>
      pre:has(> code) {
        background-color: transparent !important;
        border: 1px solid #e7e5e4 !important;
        white-space: pre-wrap;
        padding: 1em;
        border-radius: 6px;
      }
      html.dark pre:has(> code) {
        background-color: #131313 !important;
        border-color: #1f1f1f !important;
      }
      html.dark .astro-code,
      html.dark .astro-code span {
        color: var(--shiki-dark) !important;
        background-color: var(--shiki-dark-bg) !important;
        font-style: var(--shiki-dark-font-style) !important;
        font-weight: var(--shiki-dark-font-weight) !important;
        text-decoration: var(--shiki-dark-text-decoration) !important;
      }
    </style>
  </body>
</html>
