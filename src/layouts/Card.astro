---
interface Props {
  title: string
  description: string
  pubDate?: string
}

const { title, description, pubDate } = Astro.props as Props
---

<article
  class='group flex flex-col gap-1 border-b border-line py-4 transition-colors hover:border-ink/40'
>
  <div class='flex items-baseline justify-between gap-4'>
    <h3
      class='text-[15px] font-medium text-ink transition-transform group-hover:translate-x-0.5'
    >
      {title}
    </h3>
    {
      pubDate && (
        <time class='shrink-0 font-mono text-[11px] text-muted'>
          {pubDate}
        </time>
      )
    }
  </div>
  <p class='text-sm text-muted line-clamp-2'>
    {description}
  </p>
</article>
