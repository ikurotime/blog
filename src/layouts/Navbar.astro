---
import LanguagePicker from '../components/LanguagePicker.astro'
import DarkModeToggle from '../components/DarkModeToggle.astro'
import { getLangFromUrl } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
---

<header
  class='flex justify-between items-center py-6 text-sm reveal'
  style='--reveal-delay: 0ms'
>
  <a
    href={`/${lang}/`}
    class='group flex items-center gap-2 font-medium tracking-tight'
    aria-label='Home'
  >
    <span
      class='inline-flex justify-center items-center bg-ink rounded-md w-6 h-6 font-mono text-[11px] text-bg group-hover:-rotate-6 transition-transform'
      >🚀</span
    >
    <span class='text-ink'>kuro</span>
  </a>
  <nav class='flex items-center gap-4 text-muted'>
    <LanguagePicker />
    <DarkModeToggle />
  </nav>
</header>
